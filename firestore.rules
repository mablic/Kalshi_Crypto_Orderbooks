rules_version = '2';

// Deploy from this folder:
//   firebase deploy --only firestore:rules
// Requires: firebase login, and .firebaserc with the correct project ID.
//
// Tighten for production: e.g. allow read only if request.auth != null

service cloud.firestore {
  match /databases/{database}/documents {

    // Kalshi market docs + minute snapshots (written by Admin SDK; web is read-only)
    match /kalshi/{marketId} {
      allow read: if true;
      allow write: if false;

      match /snapshots/{snapId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // CF index OHLC bars by series + UTC day (written by Admin SDK; web read-only)
    match /crypto/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy trading dashboard (unchanged pattern: client read-only)
    match /positions/{strategyId} {
      allow read: if true;
      allow write: if false;
    }

    match /strategies/{strategyId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
